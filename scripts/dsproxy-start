#!/usr/bin/env bash
set -euo pipefail

export NO_PROXY="127.0.0.1,localhost,${NO_PROXY:-}"
export no_proxy="127.0.0.1,localhost,${no_proxy:-}"

PROJECT="${DEEPSEEK_PROXY_PROJECT:-$HOME/projects/deepseek-responses-proxy}"
ENV_FILE="${DEEPSEEK_PROXY_ENV_FILE:-$HOME/.config/deepseek-responses-proxy/env}"
LOG_FILE="$PROJECT/proxy.log"
PID_FILE="$PROJECT/proxy.pid"
PORT="8000"

if curl --noproxy '*' -fsS "http://127.0.0.1:${PORT}/v1/models" >/dev/null 2>&1; then
  exit 0
fi

if [ ! -f "$ENV_FILE" ]; then
  echo "ERROR: missing env file: $ENV_FILE" >&2
  exit 1
fi

source "$ENV_FILE"

cd "$PROJECT"
mkdir -p .tmp

nohup env \
  TMPDIR="$PROJECT/.tmp" \
  PYTHONPATH=. \
  SEARCH_PROVIDER="${SEARCH_PROVIDER:-}" \
  SERPAPI_API_KEY="${SERPAPI_API_KEY:-}" \
  DEEPSEEK_PROXY_WEB_SEARCH_PROVIDER="${DEEPSEEK_PROXY_WEB_SEARCH_PROVIDER:-${SEARCH_PROVIDER:-mock}}" \
  DEEPSEEK_PROXY_SERPAPI_API_KEY="${DEEPSEEK_PROXY_SERPAPI_API_KEY:-}" \
  DEEPSEEK_PROXY_WEB_SEARCH_MAX_RESULTS="${DEEPSEEK_PROXY_WEB_SEARCH_MAX_RESULTS:-5}" \
  DEEPSEEK_PROXY_WEB_SEARCH_TIMEOUT_SECONDS="${DEEPSEEK_PROXY_WEB_SEARCH_TIMEOUT_SECONDS:-20}" \
  IMAGE_PROVIDER="${IMAGE_PROVIDER:-}" \
  ZAI_API_KEY="${ZAI_API_KEY:-}" \
  ZHIPUAI_API_KEY="${ZHIPUAI_API_KEY:-}" \
  ZHIPU_API_KEY="${ZHIPU_API_KEY:-}" \
  GLM_API_KEY="${GLM_API_KEY:-}" \
  DEEPSEEK_PROXY_IMAGE_PROVIDER="${DEEPSEEK_PROXY_IMAGE_PROVIDER:-${IMAGE_PROVIDER:-mock}}" \
  DEEPSEEK_PROXY_IMAGE_API_KEY="${DEEPSEEK_PROXY_IMAGE_API_KEY:-}" \
  DEEPSEEK_PROXY_IMAGE_MODEL="${DEEPSEEK_PROXY_IMAGE_MODEL:-cogView-4-250304}" \
  DEEPSEEK_PROXY_IMAGE_SIZE="${DEEPSEEK_PROXY_IMAGE_SIZE:-1024x1024}" \
  DEEPSEEK_PROXY_IMAGE_DOWNLOAD="${DEEPSEEK_PROXY_IMAGE_DOWNLOAD:-0}" \
  DEEPSEEK_PROXY_IMAGE_OUTPUT_DIR="${DEEPSEEK_PROXY_IMAGE_OUTPUT_DIR:-$PROJECT/.generated/images}" \
  DEEPSEEK_PROXY_IMAGE_MAX_ARTIFACTS="${DEEPSEEK_PROXY_IMAGE_MAX_ARTIFACTS:-100}" \
  DEEPSEEK_PROXY_FORWARD_CUSTOM_APPLY_PATCH="${DEEPSEEK_PROXY_FORWARD_CUSTOM_APPLY_PATCH:-0}" \
  DEEPSEEK_API_KEY="$DEEPSEEK_API_KEY" \
  DEEPSEEK_PROXY_MODEL="${DEEPSEEK_PROXY_MODEL:-deepseek-v4-pro}" \
  .venv/bin/python -m uvicorn deepseek_responses_proxy.app:app \
    --host 127.0.0.1 \
    --port "$PORT" \
  > "$LOG_FILE" 2>&1 &

echo $! > "$PID_FILE"

for i in {1..10}; do
  if curl --noproxy '*' -fsS "http://127.0.0.1:${PORT}/v1/models" >/dev/null 2>&1; then
    break
  fi
  sleep 1
done

if ! curl --noproxy '*' -fsS "http://127.0.0.1:${PORT}/v1/models" >/dev/null 2>&1; then
  echo "ERROR: DeepSeek proxy failed to start after 10 seconds. Last logs:" >&2
  tail -80 "$LOG_FILE" >&2
  exit 1
fi
