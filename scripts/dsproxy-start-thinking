#!/usr/bin/env bash
set -euo pipefail

export NO_PROXY="127.0.0.1,localhost,${NO_PROXY:-}"
export no_proxy="127.0.0.1,localhost,${no_proxy:-}"

PROJECT="${DEEPSEEK_PROXY_PROJECT:-$HOME/projects/deepseek-responses-proxy}"
ENV_FILE="${DEEPSEEK_PROXY_ENV_FILE:-$HOME/.config/deepseek-responses-proxy/env}"
LOG_FILE="$PROJECT/proxy-thinking.log"
PID_FILE="$PROJECT/proxy-thinking.pid"
DB_FILE="${DEEPSEEK_PROXY_THINKING_DB:-$HOME/.local/state/deepseek-responses-proxy/responses-thinking.sqlite3}"
PORT="8001"

if curl --noproxy '*' -fsS "http://127.0.0.1:${PORT}/v1/models" >/dev/null 2>&1; then
  exit 0
fi

if [ ! -f "$ENV_FILE" ]; then
  echo "ERROR: missing env file: $ENV_FILE" >&2
  exit 1
fi

source "$ENV_FILE"

cd "$PROJECT"
mkdir -p .tmp .debug
mkdir -p "$(dirname "$DB_FILE")"

nohup env \
  DEEPSEEK_THINKING=enabled \
  DEEPSEEK_PROXY_DB_PATH="$DB_FILE" \
  DEEPSEEK_REASONING_EFFORT="${DEEPSEEK_REASONING_EFFORT:-max}" \
  TMPDIR="$PROJECT/.tmp" \
  PYTHONPATH=. \
  DEEPSEEK_API_KEY="$DEEPSEEK_API_KEY" \
  .venv/bin/python -m uvicorn deepseek_responses_proxy.app:app \
    --host 127.0.0.1 \
    --port "$PORT" \
  > "$LOG_FILE" 2>&1 &

echo $! > "$PID_FILE"

for i in {1..10}; do
  if curl --noproxy '*' -fsS "http://127.0.0.1:${PORT}/v1/models" >/dev/null 2>&1; then
    break
  fi
  sleep 1
done

if ! curl --noproxy '*' -fsS "http://127.0.0.1:${PORT}/v1/models" >/dev/null 2>&1; then
  echo "ERROR: DeepSeek thinking proxy failed to start after 10 seconds. Last logs:" >&2
  tail -80 "$LOG_FILE" >&2
  exit 1
fi

echo "DeepSeek thinking proxy started on port ${PORT}, pid=$(cat "$PID_FILE")"
echo "Log: $LOG_FILE"
echo "DB: $DB_FILE"
