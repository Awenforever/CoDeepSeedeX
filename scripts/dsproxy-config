#!/usr/bin/env bash
set -euo pipefail

ENV_FILE="${DEEPSEEK_PROXY_ENV_FILE:-$HOME/.config/deepseek-responses-proxy/env}"
CODEX_CONFIG="${CODEX_CONFIG_FILE:-$HOME/.codex/config.toml}"
CODEX_DIR="$(dirname "$CODEX_CONFIG")"

mkdir -p "$(dirname "$ENV_FILE")"

ensure_env_file() {
  if [ ! -f "$ENV_FILE" ]; then
    cat > "$ENV_FILE" <<'ENVEOF'
export DEEPSEEK_API_KEY=""
export DEEPSEEK_PROXY_MODEL="deepseek-v4-pro"
export DEEPSEEK_REASONING_EFFORT="high"
ENVEOF
  fi
}

set_export_var() {
  local key="$1"
  local value="$2"

  ensure_env_file

  if grep -qE "^export ${key}=" "$ENV_FILE"; then
    python3 - "$ENV_FILE" "$key" "$value" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
key = sys.argv[2]
value = sys.argv[3]

lines = path.read_text(encoding="utf-8").splitlines()
out = []
for line in lines:
    if line.startswith(f"export {key}="):
        out.append(f'export {key}="{value}"')
    else:
        out.append(line)
path.write_text("\n".join(out) + "\n", encoding="utf-8")
PY
  else
    printf 'export %s="%s"\n' "$key" "$value" >> "$ENV_FILE"
  fi
}

codex_effort_for_deepseek_effort() {
  case "$1" in
    high) echo "high" ;;
    max) echo "xhigh" ;;
    *)
      echo "ERROR: effort must be high or max" >&2
      exit 2
      ;;
  esac
}

codex_profile_path() {
  local profile="$1"
  printf '%s/%s.config.toml\n' "$CODEX_DIR" "$profile"
}

patch_profile_file_key() {
  local profile="$1"
  local key="$2"
  local value="$3"
  local profile_file
  profile_file="$(codex_profile_path "$profile")"

  [ -f "$profile_file" ] || return 0

  python3 - "$profile_file" "$key" "$value" <<'PYCODEEPSEEDEX_DSPROXY_CONFIG_SPLIT_PROFILE_PATCH'
from pathlib import Path
import sys

path = Path(sys.argv[1])
key = sys.argv[2]
value = sys.argv[3]
text = path.read_text(encoding="utf-8")
lines = text.splitlines()
out = []
found = False
for line in lines:
    stripped = line.strip()
    if stripped.startswith(f"{key} = "):
        out.append(f'{key} = "{value}"')
        found = True
    else:
        out.append(line)
if not found:
    out.append(f'{key} = "{value}"')
path.write_text("\n".join(out).rstrip() + "\n", encoding="utf-8")
PYCODEEPSEEDEX_DSPROXY_CONFIG_SPLIT_PROFILE_PATCH
}

patch_codex_model() {
  local model="$1"
  patch_profile_file_key "deepseek" "model" "$model"
  patch_profile_file_key "deepseek-thinking" "model" "$model"
}

patch_codex_effort() {
  local deepseek_effort="$1"
  local codex_effort
  codex_effort="$(codex_effort_for_deepseek_effort "$deepseek_effort")"

  patch_profile_file_key "deepseek-thinking" "model_reasoning_effort" "$codex_effort"
  patch_profile_file_key "deepseek-thinking" "plan_mode_reasoning_effort" "high"
}

show_config() {
  ensure_env_file
  echo "ENV_FILE=$ENV_FILE"
  grep -E '^export DEEPSEEK_(PROXY_MODEL|REASONING_EFFORT)=' "$ENV_FILE" || true
  echo
  echo "CODEX_MAIN_CONFIG=$CODEX_CONFIG"
  if [ -f "$CODEX_CONFIG" ]; then
    grep -nA8 -E '^\[model_providers\.deepseek|^\[model_providers\.deepseek-thinking' "$CODEX_CONFIG" || true
  else
    echo "missing"
  fi
  for profile in deepseek deepseek-thinking; do
    profile_file="$(codex_profile_path "$profile")"
    echo
    echo "CODEX_PROFILE_FILE=$profile_file"
    if [ -f "$profile_file" ]; then
      grep -nE '^(model|model_provider|model_reasoning_effort|plan_mode_reasoning_effort|model_context_window|model_auto_compact_token_limit) = ' "$profile_file" || true
    else
      echo "missing"
    fi
  done
}

restart_thinking_proxy() {
  if [ "${DEEPSEEK_PROXY_CONFIG_RESTART_THINKING:-1}" = "0" ]; then
    echo "thinking proxy restart skipped because DEEPSEEK_PROXY_CONFIG_RESTART_THINKING=0"
    return 0
  fi

  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

  echo "restarting DeepSeek thinking proxy..."

  if command -v dsproxy-stop-thinking >/dev/null 2>&1; then
    dsproxy-stop-thinking || true
  elif [ -x "$script_dir/dsproxy-stop-thinking" ]; then
    "$script_dir/dsproxy-stop-thinking" || true
  else
    echo "WARNING: dsproxy-stop-thinking not found; skipping stop step" >&2
  fi

  if command -v dsproxy-start-thinking >/dev/null 2>&1; then
    dsproxy-start-thinking
  elif [ -x "$script_dir/dsproxy-start-thinking" ]; then
    "$script_dir/dsproxy-start-thinking"
  else
    echo "ERROR: dsproxy-start-thinking not found" >&2
    exit 1
  fi
}

usage() {
  cat <<'USAGE'
Usage:
  dsproxy-config show
  dsproxy-config set-model deepseek-v4-pro
  dsproxy-config set-model deepseek-v4-flash
  dsproxy-config set-effort max
  dsproxy-config set-effort high
  dsproxy-config set model <model> effort <high|max>

Configuration-changing commands automatically restart the thinking proxy.
Set DEEPSEEK_PROXY_CONFIG_RESTART_THINKING=0 to skip the restart.
USAGE
}

cmd="${1:-show}"

case "$cmd" in
  show)
    show_config
    restart_thinking_proxy
    ;;
  set-model)
    model="${2:-}"
    [ -n "$model" ] || { usage >&2; exit 2; }
    set_export_var "DEEPSEEK_PROXY_MODEL" "$model"
    patch_codex_model "$model"
    echo "model set to $model"
    restart_thinking_proxy
    ;;
  set-effort)
    effort="${2:-}"
    [ -n "$effort" ] || { usage >&2; exit 2; }
    case "$effort" in high|max) ;; *) echo "ERROR: effort must be high or max" >&2; exit 2 ;; esac
    set_export_var "DEEPSEEK_REASONING_EFFORT" "$effort"
    patch_codex_effort "$effort"
    echo "reasoning effort set to $effort"
    restart_thinking_proxy
    ;;
  set)
    shift
    while [ "$#" -gt 0 ]; do
      case "$1" in
        model)
          shift
          model="${1:-}"
          [ -n "$model" ] || { usage >&2; exit 2; }
          set_export_var "DEEPSEEK_PROXY_MODEL" "$model"
          patch_codex_model "$model"
          ;;
        effort)
          shift
          effort="${1:-}"
          [ -n "$effort" ] || { usage >&2; exit 2; }
          case "$effort" in high|max) ;; *) echo "ERROR: effort must be high or max" >&2; exit 2 ;; esac
          set_export_var "DEEPSEEK_REASONING_EFFORT" "$effort"
          patch_codex_effort "$effort"
          ;;
        *)
          usage >&2
          exit 2
          ;;
      esac
      shift
    done
    show_config
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
